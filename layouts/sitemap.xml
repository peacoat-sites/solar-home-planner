{{ printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {{- range .Pages }}
  {{- if and (not .Params.sitemap_exclude) (ne .Kind "taxonomy") (ne .Kind "term") (not .Draft) (not .Params.noindex) }}
  <url>
    <loc>{{ .Permalink }}</loc>
    {{ with .Lastmod }}<lastmod>{{ .Format "2006-01-02" }}</lastmod>{{ end }}
    {{ with .Sitemap.ChangeFreq }}<changefreq>{{ . }}</changefreq>{{ end }}
    <priority>{{ if .IsHome }}1.0{{ else if eq .Kind "page" }}0.8{{ else }}0.5{{ end }}</priority>
  </url>
  {{- end }}
  {{- end }}
</urlset>
