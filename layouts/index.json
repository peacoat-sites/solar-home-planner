{{- $index := slice -}}
{{- range (where .Site.RegularPages "Section" "posts") -}}
  {{- $index = $index | append (dict
    "title" .Title
    "summary" (.Summary | plainify | truncate 220)
    "url" .Permalink
    "categories" (.Params.categories | default slice)
    "date" (.PublishDate.Format "Jan 2, 2006")
    "image" (.Params.image | default "")
    "readingtime" .ReadingTime
  ) -}}
{{- end -}}
{{- $index | jsonify -}}
